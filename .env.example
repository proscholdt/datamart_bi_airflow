# Template de variáveis de ambiente. Copie para .env e preencha.
# O .env real é gitignored (contém segredos).

# Conta de armazenamento Azure usada pelo data mart
STORAGE_ACCOUNT_NAME=sua_conta_aqui
STORAGE_ACCOUNT_KEY=sua_chave_aqui

# Containers do data mart (defaults já estão em include/voomp/voomp_config.py)
VOOMP_CONTAINER_BRONZE=datamartbibronze
VOOMP_CONTAINER_SILVER=datamartbisilver
VOOMP_CONTAINER_GOLD=datamartbigold

# Conexão usada pelo WasbPrefixSensor (mesma conta/chave acima)
AIRFLOW_CONN_WASB_DEFAULT={"conn_type": "wasb", "login": "sua_conta_aqui", "password": "sua_chave_aqui"}
